# This is Git's per-user configuration file.
[user]
  name = lima
  email = lima@mbp
[core]
  editor = vim
  mergeoptions = --no-edit
[push]
  default = simple
[http]
  sslVerify = false
[url "https://github.com/"]
  insteadOf = git://github.com/
[credential]
  helper = osxkeychain
[init]
  defaultBranch = main
[pull]
	rebase = true
